{
  "manifest_version": 3,
  "name": "Notion2WeChat",
  "version": "0.1.0",
  "description": "Convert Notion pages to WeChat-ready HTML optimized for iOS reading.",
  "permissions": ["activeTab", "clipboardWrite", "scripting"],
  "host_permissions": ["https://www.notion.so/*"],
  "action": {
    "default_title": "Notion2WeChat"
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.notion.so/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ]
}
