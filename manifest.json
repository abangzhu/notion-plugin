{
  "manifest_version": 3,
  "name": "Notion2WeChat",
  "version": "1.0",
  "description": "Convert Notion pages to WeChat-ready HTML optimized for iOS reading.",
  "permissions": ["activeTab", "clipboardRead", "clipboardWrite", "scripting", "storage"],
  "host_permissions": [
    "https://www.notion.so/*",
    "https://*.notion.site/*",
    "https://secure.notion-static.com/*",
    "https://*.secure.notion-static.com/*",
    "https://*.amazonaws.com/*",
    "https://*.s3.amazonaws.com/*",
    "https://*.cloudfront.net/*",
    "https://api.openai.com/*",
    "https://*.feishu.cn/*",
    "https://*.larksuite.com/*",
    "https://*.byteimg.com/*"
  ],
  "action": {
    "default_title": "Notion2WeChat"
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.notion.so/*",
        "https://*.feishu.cn/*",
        "https://*.larksuite.com/*"
      ],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ]
}
